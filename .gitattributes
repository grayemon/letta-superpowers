# Ensure shell scripts always have LF line endings
*.sh text eol=lf

# Git hooks (no .sh extension) must also use LF
.githooks/* text eol=lf

# Common text files
*.md text eol=lf
*.json text eol=lf
*.js text eol=lf
*.mjs text eol=lf
*.ts text eol=lf

# Explicitly mark binary files
*.png binary
*.jpg binary
*.gif binary
